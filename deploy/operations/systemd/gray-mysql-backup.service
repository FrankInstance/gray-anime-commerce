[Unit]
Description=Gray Commerce MySQL backup
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
User=gray
Group=gray
SupplementaryGroups=docker
WorkingDirectory=/opt/gray
EnvironmentFile=-/etc/gray/operations.env
ExecStart=/usr/bin/bash /opt/gray/deploy/operations/mysql-backup.sh
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/gray/backups /run/docker.sock
RestrictSUIDSGID=true
